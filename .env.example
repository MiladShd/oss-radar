# OSS Radar — local configuration template
# -----------------------------------------
# Copy to `.env` and tweak as needed:   cp .env.example .env
# Every value is read by pydantic-settings with the OSS_RADAR_ prefix
# (see pipeline/oss_radar/config/settings.py). The defaults below are the
# safe local-demo defaults: a DuckDB file, no cloud, no API keys required.
#
# `.env` is gitignored — never commit real tokens.

# --- Environment / backend ---------------------------------------------------
# env:     local | cloud
# backend: duckdb (local file, zero cloud deps) | bigquery (managed warehouse)
OSS_RADAR_ENV=local
OSS_RADAR_BACKEND=duckdb

# --- Local warehouse (DuckDB) ------------------------------------------------
# Path to the local warehouse file the demo writes to and the dashboard reads.
OSS_RADAR_DUCKDB_PATH=oss_radar.duckdb

# --- Watchlist / pipeline knobs ----------------------------------------------
# watchlist_limit: 0 = score all curated packages; set a small number (e.g. 8)
# for a fast local demo. `cli run --limit N` overrides this per-run.
OSS_RADAR_WATCHLIST_LIMIT=8
# backfill_days: how much download history to pull per package (180 in prod).
OSS_RADAR_BACKFILL_DAYS=180

# --- GitHub (OPTIONAL for local demo) ----------------------------------------
# Without a token, GitHub REST calls are limited to ~60 req/hr and the Search
# API may return 403 — this REDUCES GitHub-derived signals but does NOT block a
# local demo run. To lift limits to 5000/hr, drop in a token. Easiest:
#   OSS_RADAR_GITHUB_TOKEN=$(gh auth token)
OSS_RADAR_GITHUB_TOKEN=
OSS_RADAR_GITHUB_REPO=MiladShd/oss-radar

# --- LLM agents / Claude (OPTIONAL for local demo) ---------------------------
# Leave blank to run the agent crew in deterministic TEMPLATE mode (no API
# calls). Set a real key (starts with sk-ant-) to enable Claude-written briefs.
OSS_RADAR_ANTHROPIC_API_KEY=
OSS_RADAR_LLM_MODEL=claude-opus-4-8
OSS_RADAR_LLM_MAX_TOKENS=1600

# --- GCP / cloud artifact paths (only needed for backend=bigquery) -----------
# Ignored entirely when BACKEND=duckdb. gcs_bucket defaults to
# <project>-oss-radar; bq_dataset is the BigQuery dataset name.
OSS_RADAR_GCP_PROJECT=
OSS_RADAR_REGION=us-central1
OSS_RADAR_BQ_DATASET=oss_radar
OSS_RADAR_GCS_BUCKET=
