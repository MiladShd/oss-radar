# Copy to .env for local runs. Everything is optional — sensible defaults apply.

# Warehouse backend: duckdb (local file) or bigquery (cloud)
OSS_RADAR_BACKEND=duckdb
OSS_RADAR_DUCKDB_PATH=oss_radar.duckdb

# Cap the watchlist for quick runs (0 = all ~90 packages)
OSS_RADAR_WATCHLIST_LIMIT=0

# GitHub token lifts API rate limits and lets the agent open PRs (optional locally)
OSS_RADAR_GITHUB_TOKEN=
OSS_RADAR_GITHUB_REPO=MiladShd/oss-radar

# Anthropic key enables Claude-powered agents; without it the crew runs in template mode
OSS_RADAR_ANTHROPIC_API_KEY=

# GCP (only needed for the bigquery backend / deploy)
OSS_RADAR_GCP_PROJECT=
OSS_RADAR_REGION=us-central1
OSS_RADAR_BQ_DATASET=oss_radar
